# ── Server ──────────────────────────────────────────────
PORT=3000
JWT_SECRET=change-me-in-production
ADMIN_USER=admin
ADMIN_PASS=change-me
DB_PATH=openclaw.db
UI_DIST_PATH=../ui/dist

# ── Provisioning ───────────────────────────────────────
# Container runtime: docker | podman (auto-detected if omitted)
# OPENCLAW_RUNTIME_PROVIDER=docker

# Directory containing docker-compose.yml and provision-docker.sh
# Relative paths are resolved from the project root (where .env lives).
OPENCLAW_RUNTIME_DIR=../openclaw

# Root directory for per-instance config & workspace data
OPENCLAW_DATA_DIR=../openclaw-data

# Host IP that containers bind to (used in gateway URLs)
OPENCLAW_HOST_IP=127.0.0.1

# Port ranges allocated to provisioned instances
OPENCLAW_GATEWAY_PORT_START=18789
OPENCLAW_GATEWAY_PORT_END=18999
OPENCLAW_BRIDGE_PORT_START=28789
OPENCLAW_BRIDGE_PORT_END=28999

# ── Domain mode (optional) ────────────────────────────
# Set base domain to enable per-instance subdomain routing via Nginx.
# Leave empty for IP:port mode.
# OPENCLAW_BASE_DOMAIN=example.com
# NGINX_SITE_DIR=/etc/nginx/conf.d/openclaw
# NGINX_RELOAD_CMD=nginx -s reload

# ── npm registry (optional) ───────────────────────────
# Mirror for pnpm install during Docker image build.
# Recommended for China mainland servers.
# NPM_CONFIG_REGISTRY=https://registry.npmmirror.com

# ── Public URL (optional) ─────────────────────────────
# The externally-reachable URL of this tenant API.
# Used by exec bootstrap wizard to call back.
# TENANT_PUBLIC_URL=https://tenant.example.com
